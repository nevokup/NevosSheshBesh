<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C3E50"
    android:fillViewport="true"
    android:layoutDirection="rtl">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/header_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="לוח תוצאות"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="חזרה"
                android:textColor="#FFFFFF"
                android:backgroundTint="#34495E" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stats_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_below="@id/header_layout"
            android:background="#1A252F"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_player_name_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="שם משתמש"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_total_games"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="משחקים: 0"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tv_wins_summary_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ניצחונות: "
                    android:textColor="#2ECC71"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_total_wins_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#2ECC71"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_win_type_regular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• ניצחון רגיל: 0"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginRight="16dp" />

            <TextView
                android:id="@+id/tv_win_type_mars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• ניצחון מארס: 0"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginRight="16dp" />

            <TextView
                android:id="@+id/tv_win_type_stars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="• ניצחון מארס כוכבים: 0"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginRight="16dp" />

            <TextView
                android:id="@+id/tv_losses_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="הפסדים: 0"
                android:textColor="#E74C3C"
                android:textSize="18sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_history_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/stats_container"
            android:text="משחקים קודמים:"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/table_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_history_label"
            android:background="#34495E"
            android:padding="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="שם היריב"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="מי ניצח"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="איזה סוג ניצחון"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/table_header"
            android:nestedScrollingEnabled="false" />

    </RelativeLayout>

</androidx.core.widget.NestedScrollView>