<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C3E50"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp"
        android:paddingTop="10dp"
        android:gravity="center_horizontal">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="חזרה"
                android:textSize="18sp"
                android:backgroundTint="#455A64"
                android:textColor="#FFFFFF"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:padding="0dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="דף הרשמה"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_centerInParent="true" />
        </RelativeLayout>

        <EditText
            android:id="@+id/et_reg_email"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="אימייל"
            android:inputType="textEmailAddress"
            android:textColorHint="#BDC3C7"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="8dp"
            android:gravity="right" />

        <EditText
            android:id="@+id/et_reg_username"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="שם משתמש"
            android:textColorHint="#BDC3C7"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="8dp"
            android:gravity="right" />

        <EditText
            android:id="@+id/et_reg_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="סיסמה"
            android:inputType="textPassword"
            android:textColorHint="#BDC3C7"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="8dp"
            android:gravity="right" />

        <EditText
            android:id="@+id/et_reg_confirm_password"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="אימות סיסמה"
            android:inputType="textPassword"
            android:textColorHint="#BDC3C7"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="8dp"
            android:gravity="right" />

        <EditText
            android:id="@+id/et_reg_age"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="גיל"
            android:inputType="number"
            android:textColorHint="#BDC3C7"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp"
            android:gravity="right" />

        <Button
            android:id="@+id/btn_register_submit"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="להרשמה"
            android:backgroundTint="#E67E22"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

    </LinearLayout>
</ScrollView>